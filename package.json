{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run check:wasm",
    "dev": "NEXT_DIST_DIR=.next-dev-${USER:-local} next dev --webpack",
    "prebuild": "npm run check:wasm",
    "build": "next build --webpack",
    "build:local": "npm run typecheck && SKIP_NEXT_TYPECHECK=1 NODE_OPTIONS=--max-old-space-size=4096 npm run build",
    "build:embed": "NEXT_PUBLIC_BUILD_MODE=embed BUILD_MODE=embed npm run build",
    "build:embed:local": "npm run typecheck && SKIP_NEXT_TYPECHECK=1 NODE_OPTIONS=--max-old-space-size=4096 NEXT_PUBLIC_BUILD_MODE=embed BUILD_MODE=embed npm run build",
    "build:embed:full": "bash scripts/build-embed-with-soundfont.sh",
    "start": "next start",
    "lint": "eslint app components lib unit tests",
    "typecheck": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "test:music-services": "vitest run unit/music-conversion.test.ts unit/convert-service.test.ts unit/context-service.test.ts unit/generate-service.test.ts unit/patch-service.test.ts unit/scoreops-service.test.ts unit/convert-route.test.ts unit/context-route.test.ts unit/generate-route.test.ts unit/scoreops-route.test.ts unit/music-agent-router.test.ts unit/music-agent-route.test.ts unit/music-specialists-tool.test.ts unit/music-service-contracts.test.ts",
    "test:watch": "vitest",
    "test:e2e:music": "playwright test tests/music-api-smoke.spec.ts --workers=1",
    "coverage": "vitest run --coverage",
    "check:wasm": "node scripts/check-wasm-cli.js",
    "sync:wasm": "node scripts/sync-wasm-cli.js",
    "generate:data": "node scripts/generate-static-data.js",
    "package:release": "node scripts/package-release.js",
    "release:prepare": "npm run build:embed && npm run package:release",
    "test:embed": "node test-embed/server.js"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.8.4",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.0",
    "@gradio/client": "^2.1.0",
    "@openai/agents": "^0.5.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "codemirror": "^6.0.1",
    "next": "^16.1.3",
    "openai": "^6.25.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "webmscore": "file:./webmscore-fork/web-public",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "file-loader": "^6.2.0",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
