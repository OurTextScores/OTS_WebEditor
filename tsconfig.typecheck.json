{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false
  },
  "include": [
    "next-env.d.ts",
    "app/api/music/scoreops/**/*.ts",
    "lib/music-services/scoreops-service.ts",
    "lib/music-services/scoreops-session-store.ts",
    "lib/music-services/contracts/**/*.ts",
    "lib/score-artifacts.ts",
    "types/typecheck-webmscore.d.ts",
    "unit/scoreops-*.test.ts",
    "unit/music-service-contracts.test.ts"
  ],
  "exclude": [
    "node_modules",
    "webmscore-fork",
    ".next",
    ".next-dev-*",
    "out",
    "release",
    "build"
  ]
}
